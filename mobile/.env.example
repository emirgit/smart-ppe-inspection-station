# WebSocket URL exposed by MOD-03 (Raspberry Pi) for the turnstile display.
# Format: ws://<RPI_IP>:<PORT>/ws/display
VITE_WS_URL=ws://192.168.1.100:8080/ws/display

# Stable client identifier sent in the DISPLAY_READY handshake.
VITE_CLIENT_ID=turnstile-display-01

# When true (or when the URL contains ?mock=1), the app skips the WebSocket
# connection and drives the state machine via MockSimulator. Useful for
# development without the RPi.
VITE_MOCK_MODE=false
